FROM node:22-slim

WORKDIR /app

ARG NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
ARG NEXT_PUBLIC_ALLOW_SENSITIVE_TRANSFER_EXPORT=false
ARG NEXT_PUBLIC_ALLOW_SENSITIVE_TRANSFER_IMPORT=false
ENV NEXT_PUBLIC_API_BASE_URL=$NEXT_PUBLIC_API_BASE_URL
ENV NEXT_PUBLIC_ALLOW_SENSITIVE_TRANSFER_EXPORT=$NEXT_PUBLIC_ALLOW_SENSITIVE_TRANSFER_EXPORT
ENV NEXT_PUBLIC_ALLOW_SENSITIVE_TRANSFER_IMPORT=$NEXT_PUBLIC_ALLOW_SENSITIVE_TRANSFER_IMPORT

COPY package*.json ./

RUN npm install

COPY . .

EXPOSE 3000

CMD ["npm", "run", "dev"]
