APP_ENV=production

POSTGRES_DB=mstracker_prod
POSTGRES_USER=mstracker
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://mstracker:change-me@db:5432/mstracker_prod

NEXT_PUBLIC_API_BASE_URL=https://dotopoly.com/api
NEXT_PUBLIC_ALLOW_SENSITIVE_TRANSFER_EXPORT=false
NEXT_PUBLIC_ALLOW_SENSITIVE_TRANSFER_IMPORT=false
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://dotopoly.com,https://api.dotopoly.com

# Generate a production-only Fernet key. Do not reuse staging or local keys.
FIELD_ENCRYPTION_KEY=replace-with-production-fernet-key
REQUIRE_FIELD_ENCRYPTION_KEY=true
ALLOW_SENSITIVE_TRANSFER_EXPORT=false
ALLOW_SENSITIVE_TRANSFER_IMPORT=false
AUTH_ENABLED=true
AUTH_DEV_BYPASS=false
AUTH_PUBLIC_DOCS=false
MFA_REQUIRED=false
MFA_ISSUER=Dotopoly
SESSION_SECRET=replace-with-production-random-secret
SESSION_COOKIE_NAME=dotopoly_session
SESSION_COOKIE_SECURE=true
SESSION_IDLE_TIMEOUT_MINUTES=720
SESSION_ABSOLUTE_TIMEOUT_DAYS=14

STORAGE_BACKEND=local
UPLOAD_ROOT=/app/uploads
UPLOADS_DIR=/app/uploads
UPLOADS_DIR_ON_HOST=/opt/dotopoly/data/prod/uploads

OCR_DEBUG=false
