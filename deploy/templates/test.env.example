APP_ENV=staging

POSTGRES_DB=mstracker_test
POSTGRES_USER=mstracker
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://mstracker:change-me@db:5432/mstracker_test

NEXT_PUBLIC_API_BASE_URL=https://test.dotopoly.com/api
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://test.dotopoly.com

FIELD_ENCRYPTION_KEY=replace-with-fernet-key
REQUIRE_FIELD_ENCRYPTION_KEY=true
AUTH_ENABLED=true
AUTH_DEV_BYPASS=false
SESSION_SECRET=replace-with-test-random-secret
SESSION_COOKIE_NAME=dotopoly_session
SESSION_COOKIE_SECURE=true
SESSION_IDLE_TIMEOUT_MINUTES=720
SESSION_ABSOLUTE_TIMEOUT_DAYS=14

STORAGE_BACKEND=local
UPLOAD_ROOT=/app/uploads
UPLOADS_DIR=/app/uploads
UPLOADS_DIR_ON_HOST=/opt/dotopoly/data/dev/uploads

OCR_DEBUG=false
