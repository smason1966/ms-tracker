DATABASE_URL=postgresql+psycopg://mstracker:change-me@db:5432/mstracker
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
APP_ENV=production
FIELD_ENCRYPTION_KEY=replace-with-fernet-key
AUTH_ENABLED=true
AUTH_DEV_BYPASS=false
AUTH_PUBLIC_DOCS=false
SESSION_SECRET=replace-with-production-random-secret
SESSION_COOKIE_NAME=dotopoly_session
SESSION_COOKIE_SECURE=true
SESSION_IDLE_TIMEOUT_MINUTES=720
SESSION_ABSOLUTE_TIMEOUT_DAYS=14

STORAGE_BACKEND=s3
UPLOADS_DIR=/app/uploads
MS_TRACKER_UPLOADS_DIR=/srv/ms-tracker/uploads

OCR_DEBUG=false

S3_BUCKET=example-ms-tracker-uploads
S3_REGION=us-east-1
S3_PREFIX=production/
